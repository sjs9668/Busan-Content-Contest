[sub_resource type="GDScript" id="GDScript_ycdy4"]
resource_name = "CharAnim.gd"
script/source = "extends AnimatedSprite2D

@export var action_hold_time: float = 0.12

func _ready() -> void:
	play(\"idle\")

func play_action(anim_name: String) -> void:
	if sprite_frames == null:
		return
	if not sprite_frames.has_animation(anim_name):
		return

	play(anim_name)

	# 연타 대응: 마지막 입력만 복귀
	var token := Time.get_ticks_msec()
	set_meta(\"token\", token)

	await get_tree().create_timer(action_hold_time).timeout
	if int(get_meta(\"token\")) != token:
		return

	play(\"idle\")
"


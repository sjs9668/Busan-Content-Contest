[gd_scene format=3 uid="uid://kl5rjcajhgaj"]

[sub_resource type="GDScript" id="GDScript_53f0o"]
resource_name = "EndingScreen.gd"
script/source = "extends Control

@export var game_scene_path: String = \"res://Main.tscn\"

@onready var stage1_label: Label = $CenterContainer/VBoxContainer/ScoreList/Stage1Label
@onready var stage2_label: Label = $CenterContainer/VBoxContainer/ScoreList/Stage2Label
@onready var stage3_label: Label = $CenterContainer/VBoxContainer/ScoreList/Stage3Label
@onready var total_label: Label  = $CenterContainer/VBoxContainer/ScoreList/TotalLabel
@onready var retry_button: Button = $CenterContainer/VBoxContainer/RetryButton

func _ready() -> void:
	# ScoreResult는 AutoLoad(싱글톤)이어야 함
	var s1: int = int(ScoreResult.stage_scores.get(1, 0))
	var s2: int = int(ScoreResult.stage_scores.get(2, 0))
	var s3: int = int(ScoreResult.stage_scores.get(3, 0))
	var total: int = int(ScoreResult.total_score)

	stage1_label.text = \"Stage 1 : %d\" % s1
	stage2_label.text = \"Stage 2 : %d\" % s2
	stage3_label.text = \"Stage 3 : %d\" % s3
	total_label.text  = \"TOTAL : %d\" % total

	retry_button.pressed.connect(_on_retry_pressed)

func _on_retry_pressed() -> void:
	ScoreResult.reset()
	get_tree().change_scene_to_file(game_scene_path)
"

